@page
@model BlogApp.Pages.Posts.CreateModel
@{
    ViewData["Title"] = "Create Post";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">Create New Blog Post</h4>
            </div>
            <div class="card-body">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    
                    <div class="mb-3">
                        <label asp-for="Post.Title" class="form-label fw-semibold"></label>
                        <input asp-for="Post.Title" class="form-control form-control-lg" placeholder="Enter post title" />
                        <span asp-validation-for="Post.Title" class="invalid-feedback d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Post.Author" class="form-label fw-semibold"></label>
                        <input asp-for="Post.Author" class="form-control" placeholder="Your name" />
                        <span asp-validation-for="Post.Author" class="invalid-feedback d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Post.Content" class="form-label fw-semibold"></label>
                        <textarea asp-for="Post.Content" class="form-control" rows="8" placeholder="Write your post content here..."></textarea>
                        <span asp-validation-for="Post.Content" class="invalid-feedback d-block"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-check-lg me-1" viewBox="0 0 16 16">
                                <path d="M12.736 3.97a.733.733 0 0 1 1.047 0c.286.289.29.756.017 1.052L7.88 12.414a.75.75 0 0 1-1.060.02L3.217 9.03a.733.733 0 0 1 1.047-1.042l3.052 3.022 5.422-5.023.975-.926z"/>
                            </svg>
                            Create Post
                        </button>
                        <a asp-page="Index" class="btn btn-secondary btn-lg">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}