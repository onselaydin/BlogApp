@page
@model BlogApp.Pages.Posts.DetailsModel
@{
    ViewData["Title"] = "Post Details";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">
                <h1 class="card-title mb-3">@Html.DisplayFor(model => model.Post.Title)</h1>
                <div class="mb-4 pb-3 border-bottom">
                    <p class="text-muted mb-1">
                        <strong>Author:</strong> @Html.DisplayFor(model => model.Post.Author)
                    </p>
                    <p class="text-muted">
                        <strong>Published:</strong> @Html.DisplayFor(model => model.Post.CreatedDate)
                    </p>
                </div>
                <div class="post-content">
                    @Html.DisplayFor(model => model.Post.Content)
                </div>
            </div>
        </div>
        
        <div class="d-flex gap-2">
            <a asp-page="./Edit" asp-route-id="@Model.Post.Id" class="btn btn-warning">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-pencil me-1" viewBox="0 0 16 16">
                    <path d="M12.146.292a.5.5 0 0 1 .708 0l3.854 3.853a.5.5 0 0 1 0 .708l-10.851 10.851a.5.5 0 0 1-.2.113l-3.79 1.263a.5.5 0 0 1-.642-.642l1.263-3.79a.5.5 0 0 1 .113-.2l10.851-10.851zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207 11.207 2.5z"/>
                </svg>
                Edit
            </a>
            <a asp-page="./Index" class="btn btn-secondary">Back to List</a>
        </div>
    </div>
</div>