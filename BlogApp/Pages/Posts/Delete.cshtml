@page
@model BlogApp.Pages.Posts.DeleteModel
@{
    ViewData["Title"] = "Delete Post";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm border-danger border-2">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0">Delete Post</h4>
            </div>
            <div class="card-body">
                <div class="alert alert-warning" role="alert">
                    <strong>Warning!</strong> Are you sure you want to delete this post? This action cannot be undone.
                </div>
                
                <div class="bg-light p-3 rounded mb-4">
                    <h5 class="mb-3">@Html.DisplayFor(model => model.Post.Title)</h5>
                    <dl class="row mb-0">
                        <dt class="col-sm-3 fw-semibold">Author:</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.Post.Author)</dd>
                        <dt class="col-sm-3 fw-semibold">Created:</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.Post.CreatedDate)</dd>
                        <dt class="col-sm-3 fw-semibold">Content:</dt>
                        <dd class="col-sm-9">
                            @{
                                var content = Html.DisplayFor(modelItem => modelItem.Post.Content).ToString();
                                if (content.Length > 150)
                                {
                                    @Html.Raw(content.Substring(0, 150) + "...")
                                }
                                else
                                {
                                    @Html.DisplayFor(modelItem => modelItem.Post.Content)
                                }
                            }
                        </dd>
                    </dl>
                </div>

                <form method="post" class="d-flex gap-2">
                    <input type="hidden" asp-for="Post.Id" />
                    <button type="submit" class="btn btn-danger btn-lg">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash me-1" viewBox="0 0 16 16">
                            <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6z"/>
                            <path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118zM2.5 1a.5.5 0 0 0-.5.5v1h11V1.5a.5.5 0 0 0-.5-.5h-11z"/>
                        </svg>
                        Delete Post
                    </button>
                    <a asp-page="./Index" class="btn btn-secondary btn-lg">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>