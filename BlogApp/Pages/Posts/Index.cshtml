@page
@model BlogApp.Pages.Posts.IndexModel
@{
    ViewData["Title"] = "Blog Posts";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2">Blog Posts</h1>
    <a asp-page="Create" class="btn btn-primary">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-plus-lg me-1" viewBox="0 0 16 16">
            <path fill-rule="evenodd" d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2Z"/>
        </svg>
        Create New Post
    </a>
</div>

@if (Model.Post.Count == 0)
{
    <div class="alert alert-info" role="alert">
        <strong>No posts yet.</strong> <a asp-page="Create">Create the first one!</a>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var item in Model.Post)
        {
            <div class="col-lg-6 col-xl-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body">
                        <h5 class="card-title">@Html.DisplayFor(modelItem => item.Title)</h5>
                        <p class="card-text text-muted">
                            <small>@Html.DisplayFor(modelItem => item.Author)</small>
                        </p>
                        <p class="card-text">
                            @{
                                var content = Html.DisplayFor(modelItem => item.Content).ToString();
                                if (content.Length > 100)
                                {
                                    @Html.Raw(content.Substring(0, 100) + "...")
                                }
                                else
                                {
                                    @Html.DisplayFor(modelItem => item.Content)
                                }
                            }
                        </p>
                        <p class="card-text">
                            <small class="text-muted">@Html.DisplayFor(modelItem => item.CreatedDate)</small>
                        </p>
                    </div>
                    <div class="card-footer bg-transparent border-top-0 pt-0">
                        <div class="btn-group w-100" role="group">
                            <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm">Details</a>
                            <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm">Edit</a>
                            <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">Delete</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}