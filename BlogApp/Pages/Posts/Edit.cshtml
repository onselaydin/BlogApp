@page
@model BlogApp.Pages.Posts.EditModel
@{
    ViewData["Title"] = "Edit Post";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-warning text-dark">
                <h4 class="mb-0">Edit Blog Post</h4>
            </div>
            <div class="card-body">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    <input type="hidden" asp-for="Post.Id" />
                    
                    <div class="mb-3">
                        <label asp-for="Post.Title" class="form-label fw-semibold"></label>
                        <input asp-for="Post.Title" class="form-control form-control-lg" />
                        <span asp-validation-for="Post.Title" class="invalid-feedback d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Post.Author" class="form-label fw-semibold"></label>
                        <input asp-for="Post.Author" class="form-control" />
                        <span asp-validation-for="Post.Author" class="invalid-feedback d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Post.Content" class="form-label fw-semibold"></label>
                        <textarea asp-for="Post.Content" class="form-control" rows="8"></textarea>
                        <span asp-validation-for="Post.Content" class="invalid-feedback d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Post.CreatedDate" class="form-label fw-semibold">Created Date</label>
                        <input asp-for="Post.CreatedDate" class="form-control" type="datetime-local" />
                        <span asp-validation-for="Post.CreatedDate" class="invalid-feedback d-block"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning btn-lg btn-dark">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-clockwise me-1" viewBox="0 0 16 16">
                                <path fill-rule="evenodd" d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 0-.908-.417A4 4 0 1 1 8 7a.5.5 0 0 0 0-1zm0-4a.5.5 0 0 1 .5.5v1.5a.5.5 0 0 1-1 0V.5A.5.5 0 0 1 8 0z"/>
                            </svg>
                            Save Changes
                        </button>
                        <a asp-page="./Index" class="btn btn-secondary btn-lg">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}